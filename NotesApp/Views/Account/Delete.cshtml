@model NotesApp.Models.ViewModels.DeleteAccountViewModel

@{
    ViewData["Title"] = "Zrušení účtu";
}

<h1>Zrušení účtu</h1>

<div class="alert alert-warning" role="alert">
    Tato akce je nevratná. Po potvrzení se odstraní tvůj účet i všechny poznámky.
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-danger">Trvale zrušit účet</button>
    <a asp-controller="Notes" asp-action="Index" class="btn btn-outline-secondary">Zpět</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
