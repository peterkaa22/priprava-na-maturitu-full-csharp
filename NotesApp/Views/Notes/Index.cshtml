@model NotesApp.Models.ViewModels.NotesIndexViewModel

@{
    ViewData["Title"] = "Moje poznámky";
}

<h1>Moje poznámky</h1>

<div class="mb-3">
    @if (Model.ShowImportantOnly)
    {
        <a asp-action="Index" asp-route-importantOnly="false" class="btn btn-outline-secondary btn-sm">Zobrazit všechny poznámky</a>
    }
    else
    {
        <a asp-action="Index" asp-route-importantOnly="true" class="btn btn-outline-warning btn-sm">Zobrazit jen důležité</a>
    }
</div>

<div class="card mb-4">
    <div class="card-header">Nová poznámka</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="ShowImportantOnly" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="NewNote.Title" class="form-label"></label>
                <input asp-for="NewNote.Title" class="form-control" />
                <span asp-validation-for="NewNote.Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewNote.Content" class="form-label"></label>
                <textarea asp-for="NewNote.Content" class="form-control" rows="5"></textarea>
                <span asp-validation-for="NewNote.Content" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Uložit poznámku</button>
        </form>
    </div>
</div>

<h2>Seznam poznámek</h2>

@if (Model.Notes.Count == 0)
{
    <p>Zatím nemáš žádné poznámky.</p>
}
else
{
    <div class="list-group">
        @foreach (var note in Model.Notes)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <h5 class="mb-1">@note.Title</h5>
                        @if (note.IsImportant)
                        {
                            <span class="badge text-bg-warning mb-2">Důležitá</span>
                        }
                        <small class="text-muted">@note.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                        <p class="mt-2 mb-0" style="white-space: pre-wrap;">@note.Content</p>
                    </div>
                    <div class="d-flex flex-column gap-2">
                        <form asp-action="ToggleImportant" method="post">
                            <input type="hidden" name="id" value="@note.Id" />
                            <input type="hidden" name="importantOnly" value="@Model.ShowImportantOnly" />
                            @Html.AntiForgeryToken()
                            @if (note.IsImportant)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-warning">Odebrat důležitost</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-warning">Označit jako důležitou</button>
                            }
                        </form>
                        <form asp-action="Delete" method="post">
                            <input type="hidden" name="id" value="@note.Id" />
                            <input type="hidden" name="importantOnly" value="@Model.ShowImportantOnly" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Smazat</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}